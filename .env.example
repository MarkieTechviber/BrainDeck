# ============================================
# BRAINDECK — Environment Template
# Copy this file to .env and fill in values
# ============================================

NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000
APP_NAME=BrainDeck

# AI Mode: "local" (Ollama) or "cloud" (Claude API)
AI_MODE=local

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

MAX_FILE_SIZE_MB=20
ALLOWED_EXTENSIONS=pdf,docx,pptx,txt,md
UPLOAD_DIR=./uploads

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

CORS_ORIGIN=http://localhost:3000

# MySQL (XAMPP default settings)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=braindeck
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=          # Gmail: use App Password (not your real password)
EMAIL_FROM=BrainDeck <noreply@braindeck.app>
# Gmail app password: myaccount.google.com → Security → 2FA → App passwords

# ── Google OAuth ───────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
SESSION_SECRET=braindeck-session-secret-CHANGE-ME

# ── Push Notifications (VAPID) ─────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@braindeck.app
PUSH_SCHEDULE=0 8 * * *
STREAK_REMINDER_SCHEDULE=0 21 * * *
